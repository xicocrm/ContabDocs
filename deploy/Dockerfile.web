FROM node:20-alpine AS base
RUN npm install -g pnpm@9
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY artifacts/contabdoc/package.json ./artifacts/contabdoc/
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY lib/api-zod/package.json ./lib/api-zod/
COPY lib/db/package.json ./lib/db/
RUN pnpm install --frozen-lockfile --ignore-scripts

FROM deps AS builder
COPY . .
RUN pnpm --filter @workspace/api-client-react exec tsc -p tsconfig.json 2>/dev/null || true
RUN BASE_PATH=/ PORT=80 pnpm --filter @workspace/contabdoc run build

FROM nginx:alpine AS runner
COPY --from=builder /app/artifacts/contabdoc/dist/public /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
