FROM node:20-alpine AS builder
RUN npm install -g pnpm@9
WORKDIR /app

# Copia tudo do monorepo (necessario para catalogo pnpm e workspace packages)
COPY . .

# Instala dependencias e compila o frontend
RUN pnpm install --no-frozen-lockfile --ignore-scripts
RUN pnpm --filter @workspace/contabdoc run build

FROM nginx:alpine
COPY --from=builder /app/artifacts/contabdoc/dist/public /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
