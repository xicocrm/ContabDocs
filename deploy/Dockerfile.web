FROM node:20-alpine AS builder
RUN npm install -g pnpm@9
WORKDIR /app

# Copia todo o workspace (necessário para resolver dependências internas do pnpm)
COPY . .

# Instala dependências (--ignore-scripts evita builds nativos desnecessários)
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# Compila apenas o frontend
RUN NODE_ENV=production pnpm --filter @workspace/contabdoc run build

FROM nginx:alpine
COPY --from=builder /app/artifacts/contabdoc/dist/public /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
