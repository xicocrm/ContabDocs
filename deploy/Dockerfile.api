FROM node:20-slim AS builder
RUN npm install -g pnpm@9
WORKDIR /app

COPY . .

RUN pnpm install --no-frozen-lockfile

RUN pnpm --filter @workspace/api-server run build

FROM node:20-slim AS runner
WORKDIR /app

COPY --from=builder /app/artifacts/api-server/dist ./artifacts/api-server/dist
COPY --from=builder /app/artifacts/api-server/package.json ./artifacts/api-server/package.json
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./

COPY --from=builder /app/lib/db/src ./lib/db/src
COPY --from=builder /app/lib/db/package.json ./lib/db/package.json
COPY --from=builder /app/lib/db/tsconfig.json ./lib/db/tsconfig.json
COPY --from=builder /app/lib/db/drizzle.config.ts ./lib/db/drizzle.config.ts
COPY --from=builder /app/lib/api-zod ./lib/api-zod
COPY --from=builder /app/lib/integrations-anthropic-ai/src ./lib/integrations-anthropic-ai/src
COPY --from=builder /app/lib/integrations-anthropic-ai/package.json ./lib/integrations-anthropic-ai/package.json

RUN mkdir -p /app/uploads && chown -R node:node /app/uploads

ENV NODE_ENV=production
USER node
WORKDIR /app/artifacts/api-server
EXPOSE 3001
CMD ["node", "--enable-source-maps", "./dist/index.mjs"]
