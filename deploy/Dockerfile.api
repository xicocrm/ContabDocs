FROM node:20-alpine AS base
RUN npm install -g pnpm@9
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-workspace.yaml ./
COPY artifacts/api-server/package.json ./artifacts/api-server/
COPY lib/db/package.json lib/db/tsconfig.json ./lib/db/
COPY lib/api-zod/package.json ./lib/api-zod/
COPY lib/integrations-anthropic-ai/package.json ./lib/integrations-anthropic-ai/
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --no-lockfile --ignore-scripts && \
    npx --yes esbuild --version >/dev/null 2>&1 || true

FROM deps AS builder
COPY artifacts/api-server ./artifacts/api-server
COPY lib ./lib
RUN pnpm --filter @workspace/api-server run build

FROM node:20-alpine AS runner
WORKDIR /app

COPY --from=builder /app/artifacts/api-server/dist ./artifacts/api-server/dist
COPY --from=builder /app/artifacts/api-server/package.json ./artifacts/api-server/package.json
COPY --from=deps /app/node_modules ./node_modules
COPY package.json ./

COPY lib/db/src ./lib/db/src
COPY lib/db/package.json lib/db/tsconfig.json ./lib/db/
COPY lib/db/drizzle.config.ts ./lib/db/drizzle.config.ts
COPY lib/api-zod ./lib/api-zod
COPY lib/integrations-anthropic-ai/src ./lib/integrations-anthropic-ai/src
COPY lib/integrations-anthropic-ai/package.json ./lib/integrations-anthropic-ai/

RUN mkdir -p /app/uploads && chown -R node:node /app/uploads

ENV NODE_ENV=production
USER node
WORKDIR /app/artifacts/api-server
EXPOSE 3001
CMD ["node", "--enable-source-maps", "./dist/index.mjs"]
